{
    "name": "clean-portfolio-website",
    "version": "1.0.0",
    "description": "A clean, modern, and responsive portfolio website built with React, TypeScript, and Vite — simulating a Fedora 43 GNOME 49 desktop",
    "type": "module",
    "main": "index.html",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint \"src/**/*.{ts,tsx}\" \"test/**/*.js\" \"js/**/*.js\"",
        "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"test/**/*.js\" \"js/**/*.js\" --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "test": "vitest run --config vitest.config.js",
        "test:watch": "vitest --config vitest.config.js",
        "validate": "npm run lint && npm run typecheck && npm run test"
    },
    "keywords": [
        "portfolio",
        "clean-design",
        "minimalist",
        "responsive",
        "react",
        "typescript",
        "vite",
        "web-portfolio",
        "modern-css",
        "typography",
        "professional",
        "javascript",
        "css3",
        "html5"
    ],
    "author": "Saw Ye Htet <minwn2244@gmail.com>",
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@tailwindcss/vite": "^4.2.4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.4",
        "eslint": "^9.0.0",
        "globals": "^14.0.0",
        "jsdom": "^29.0.2",
        "prettier": "^3.2.0",
        "tailwindcss": "^4.2.4",
        "terser": "^5.27.0",
        "typescript": "^5.4.0",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/sawyairhtet/portfolio.git"
    },
    "homepage": "https://sawyehtet.com",
    "bugs": {
        "url": "https://github.com/sawyairhtet/portfolio/issues"
    },
    "engines": {
        "node": ">=14.0.0"
    },
    "browserslist": [
        "> 1%",
        "last 2 versions",
        "not dead"
    ],
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@tanstack/react-query": "^5.100.1",
        "axios": "^1.15.2",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-hook-form": "^7.73.1",
        "react-router-dom": "^7.14.2",
        "zod": "^4.3.6"
    }
}
