{
    "name": "clean-portfolio-website",
    "version": "1.0.0",
    "description": "A clean, modern, and responsive portfolio website built with vanilla HTML, CSS, and JavaScript",
    "type": "module",
    "main": "index.html",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint js/",
        "lint:fix": "eslint js/ --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc -p jsconfig.json --noEmit",
        "test": "vitest run --config vitest.config.js",
        "test:watch": "vitest --config vitest.config.js",
        "validate": "npm run lint && npm run typecheck && npm run test"
    },
    "keywords": [
        "portfolio",
        "clean-design",
        "minimalist",
        "responsive",
        "vanilla-javascript",
        "web-portfolio",
        "modern-css",
        "typography",
        "professional",
        "javascript",
        "css3",
        "html5"
    ],
    "author": "Saw Ye Htet <minwn2244@gmail.com>",
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@vitest/coverage-v8": "^4.1.4",
        "eslint": "^9.0.0",
        "globals": "^14.0.0",
        "jsdom": "^29.0.2",
        "prettier": "^3.2.0",
        "terser": "^5.27.0",
        "typescript": "^5.4.0",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/sawyairhtet/portfolio.git"
    },
    "homepage": "https://sawyehtet.com",
    "bugs": {
        "url": "https://github.com/sawyairhtet/portfolio/issues"
    },
    "engines": {
        "node": ">=14.0.0"
    },
    "browserslist": [
        "> 1%",
        "last 2 versions",
        "not dead"
    ]
}
